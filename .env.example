# Supabase
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth gate. Leave false (or unset) and the app works with no login (current
# behaviour). Set to true — AND run supabase/auth-lockdown.sql + create a user —
# to require login and lock the data to authenticated users only.
VITE_REQUIRE_AUTH=false
