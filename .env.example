# Supabase
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth gate. Leave false (or unset) and the app works with no login (current
# behaviour). Set to true — AND run supabase/auth-lockdown.sql + create a user —
# to require login and lock the data to authenticated users only.
VITE_REQUIRE_AUTH=false

# SSO portal callback (api/portal-callback.ts — the portal redirects to
# https://ranking-reports-alpha.vercel.app/api/portal-callback?token=...).
# Server-only — set these in Vercel (Production), never with a VITE_ prefix.
# SUPABASE_URL is optional: when unset the function falls back to the existing
# VITE_SUPABASE_URL above (server-side process.env access ignores the VITE_
# prefix — that only governs Vite's client-bundle inlining). APP_URL is the
# canonical app origin used for redirects; when unset the request host is used.
# PORTAL_JWKS_URL=https://dashboard-portal-tawny.vercel.app/api/sso/jwks
# PORTAL_ISSUER=https://dashboard-portal-tawny.vercel.app
# SSO_AUDIENCE=3b3a26b1-c89d-4d2f-ba2e-d88f743f062d
# SUPABASE_URL=your-project-url
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# APP_URL=https://ranking-reports-alpha.vercel.app

# Set to 'true' to require sign-in + admin approval to use the app (see
# supabase/auth-approved-lockdown.sql for the full flip checklist).
VITE_REQUIRE_AUTH=false
